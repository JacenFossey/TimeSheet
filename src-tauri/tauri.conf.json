{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timesheet",
  "version": "1.7.3",
  "identifier": "com.keypak.timesheet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Timesheet",
        "url": "index.html",
        "width": 1200,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#0f1117"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/JacenFossey/TimeSheet/releases/latest/download/latest.json"
      ]
    }
  }
}
