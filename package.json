{
  "name": "timesheet",
  "version": "1.7.3",
  "description": "Daily Timesheet",
  "author": "Jacen Fossey",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.keypak.timesheet",
    "productName": "Timesheet",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "publish": {
      "provider": "github",
      "owner": "JacenFossey",
      "repo": "TimeSheet",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true
    }
  }
}
