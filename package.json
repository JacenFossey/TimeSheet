{
  "name": "timesheet",
  "version": "1.2.0",
  "description": "Daily Timesheet",
  "author": "Jacen Fossey",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.31"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.keypak.timesheet",
    "productName": "Timesheet",
    "asarUnpack": ["node_modules/node-sqlite3-wasm/**/*"],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true
    }
  }
}
